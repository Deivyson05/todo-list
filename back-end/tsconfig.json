{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "Node",
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "strict": true,
        "skipLibCheck": true,
        "types": [
            "node"
        ] // <- isso faz o TS reconhecer process, __dirname, etc.
    },
    // "include": [
    //     "src/**/*"
    // ],
    "exclude": [
        "node_modules"
    ]
}